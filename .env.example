# ============================================================
# PPT Agent — 환경변수 설정 예시
# 이 파일을 복사해서 .env 로 저장하고 값을 채워주세요.
#   cp .env.example .env
# ============================================================

# ------------------------------------------------------------
# LLM (필수)
# ------------------------------------------------------------

# API 키 (필수)
OPENAI_API_KEY=sk-...

# 사용할 모델명 (기본: claude-opus-4-5)
MODEL_NAME=claude-opus-4-5

# OpenAI 호환 커스텀 엔드포인트 (기본 Anthropic API 사용 시 비워두기)
# OPENAI_BASE_URL=https://your-proxy.example.com/v1

# LLM 요청 타임아웃 (초, 기본: 120)
# LLM_TIMEOUT=120

# ------------------------------------------------------------
# Heavy-Reflect — VLM 시각 검토 (선택)
# ------------------------------------------------------------

# 활성화 시 1 로 설정 (DESIGN_MODEL_NAME 도 함께 설정 필요)
# DEEPPRESENTER_HEAVY_REFLECT=1

# Heavy-reflect 전용 멀티모달 모델
# DESIGN_MODEL_NAME=claude-opus-4-5

# ------------------------------------------------------------
# Design 에이전트 커스텀 설정 (선택)
# ------------------------------------------------------------

# 커스텀 role YAML 파일 경로 (.yaml/.yml)
# DESIGN_CONFIG_FILE=/path/to/design-hynix.yaml

# 커스텀 디자인 가이드 파일 경로 (.md)
# DESIGN_TEMPLATE_FILE=/path/to/design-guide.md

# ------------------------------------------------------------
# 서버 설정 (선택)
# ------------------------------------------------------------

# 바인드 호스트 (기본: 0.0.0.0)
# HOST=0.0.0.0

# 바인드 포트 (기본: 5000)
# PORT=5000

# 코드 변경 시 자동 재시작 — 운영 환경에서는 false (기본: true)
# RELOAD=true

# 로그 레벨: debug / info / warning / error / critical (기본: info)
# LOG_LEVEL=info

# ------------------------------------------------------------
# Playwright / Chromium (선택)
# ------------------------------------------------------------

# Chromium 실행 파일 경로 (시스템 PATH에 없는 경우)
# PLAYWRIGHT_CHROMIUM_EXECUTABLE_PATH=/path/to/chrome

# ------------------------------------------------------------
# 에이전트 동작 세부 조정 (선택)
# ------------------------------------------------------------

# 워크스페이스 루트 디렉터리 (기본: deeppresenter/output/YYYYMMDD)
# DEEPPRESENTER_WORKSPACE_BASE=/path/to/workspace

# 로깅 레벨 숫자값 (기본: 20 = INFO)
# DEEPPRESENTER_LOG_LEVEL=20

# 도구 출력 최대 길이 (기본: 4096)
# TOOL_CUTOFF_LEN=4096

# 컨텍스트 길이 제한 (기본: 200000)
# CONTEXT_LENGTH_LIMIT=200000

# 턴당 최대 도구 호출 횟수 (기본: 7)
# MAX_TOOLCALL_PER_TURN=7

# 재시도 횟수 (기본: 3)
# RETRY_TIMES=3

# VLM에 전달하는 최대 이미지 수 (기본: 2)
# VLM_MAX_IMAGES=2
