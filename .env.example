# LLM 설정 — .env.example을 복사해서 .env로 만들어 사용
# cp .env.example .env

# 사용할 모델명
MODEL_NAME=claude-opus-4-5

# OpenAI-compatible base URL (Anthropic, Azure, Ollama 등)
# Anthropic: https://api.anthropic.com/v1
# 기본 OpenAI: 비워두면 자동으로 api.openai.com 사용
OPENAI_BASE_URL=https://api.anthropic.com/v1

# API 키
OPENAI_API_KEY=sk-ant-...

# 서버 설정 (선택)
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=debug
